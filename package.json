{
  "name": "silver-ui",
  "version": "0.8.0",
  "packageManager": "pnpm@11.3.0",
  "description": "A comprehensive themeable React component library",
  "license": "MIT",
  "homepage": "https://silver-ui.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/czarandy/silver-ui.git"
  },
  "bugs": {
    "url": "https://github.com/czarandy/silver-ui/issues"
  },
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./dist/styles.css",
    "./*": {
      "import": {
        "types": "./dist/components/*/index.d.ts",
        "default": "./dist/components/*/index.js"
      },
      "require": {
        "types": "./dist/components/*/index.d.ts",
        "default": "./dist/components/*/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepare": "husky && panda codegen",
    "storybook": "storybook dev -p 6006 --ci",
    "build": "panda codegen && tsup && node scripts/preserve-use-client.mjs && tsc -p tsconfig.build.json && node scripts/rewrite-declaration-aliases.mjs && panda cssgen --outfile dist/styles.css --minify",
    "build:storybook": "panda codegen && storybook build",
    "sync:brand": "cp brand/logo.svg brand/wordmark.svg site/public/",
    "build:site": "pnpm sync:brand && pnpm build && pnpm -C site build",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke:package": "pnpm build && node scripts/package-smoke-test.mjs",
    "lint": "eslint --cache .",
    "lint:fix": "eslint --cache --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "check:exports": "pnpm build && publint",
    "clean": "rm -rf dist storybook-static",
    "theme": "npx tsx scripts/generate-theme.ts",
    "release": "bash scripts/release.sh"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^5.8.5",
    "@eslint/js": "^10.0.1",
    "@pandacss/dev": "^1.11.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/addon-themes": "^10.4.1",
    "@storybook/react": "^10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "@vitest/eslint-plugin": "^1.6.18",
    "eslint": "^10.4.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jest-dom-ya": "^1.0.1",
    "eslint-plugin-jsdoc": "^63.0.0",
    "eslint-plugin-jsx-a11y-x": "^0.2.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-storybook": "^10.4.1",
    "eslint-plugin-testing-library": "^7.16.2",
    "eslint-plugin-use-client": "^1.0.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "postcss": "^8.5.4",
    "prettier": "^3.5.3",
    "publint": "^0.3.21",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "storybook": "^10.4.1",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@js-temporal/polyfill": "^0.5.1",
    "lucide-react": "^1.16.0"
  }
}
