{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "silver-ui": ["../src/index.ts"],
      "components/*": ["../src/components/*"],
      "hooks/*": ["../src/hooks/*"],
      "internal": ["../src/internal/index"],
      "internal/*": ["../src/internal/*"],
      "themes/*": ["../src/themes/*"],
      "utils/*": ["../src/utils/*"],
      "styled-system/*": ["../styled-system/*"]
    },
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [".astro/types.d.ts", "src", "scripts", "astro.config.ts"],
  "exclude": ["dist"]
}
